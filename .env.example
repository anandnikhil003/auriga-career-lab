# ---- Facebook / Meta Graph API ----
# Page ID and a long-lived PAGE access token with pages_manage_posts +
# pages_read_engagement. Leave blank to run in DRY_RUN (nothing is posted).
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Force preview even if a token is set:
DRY_RUN=true
# Graph-schedule each category at its slot (recommended). false = publish now on --slot.
USE_GRAPH_SCHEDULING=true
GRAPH_VERSION=v20.0
FB_MAX_RETRIES=3

# ---- Pipeline ----
PER_CATEGORY=5
STRICT_URL_CHECK=false
HTTP_TIMEOUT=20
# Override DB path if your drive lacks SQLite locking (rare):
# AURIGA_DB=/absolute/path/opportunities.db
